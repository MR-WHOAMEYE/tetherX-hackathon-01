{
    "version": 2,
    "buildCommand": "cd frontend && npm ci && npm run build",
    "outputDirectory": "frontend/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/((?!api(?:/|$)).*)",
            "destination": "/index.html"
        }
    ],
    "env": {
        "VERCEL": "1"
    },
    "devCommand": "uvicorn app:app --host 127.0.0.1 --port $PORT --reload"
}
