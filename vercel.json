{
    "version": 2,
    "buildCommand": "cd frontend && npm install && npm run build",
    "outputDirectory": "frontend/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/ws/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/((?!api|ws).*)",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/index.py": {
            "runtime": "@vercel/python@6.20.2",
            "maxDuration": 30,
            "excludeFiles": "{pages/**,styles/**,ml_models/**,iot/**,frontend/**,.git/**}"
        }
    },
    "env": {
        "VERCEL": "1"
    }
}